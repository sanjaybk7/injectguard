{
  "name": "agentguard",
  "displayName": "agentguard",
  "description": "Static analyzer for prompt-injection and confused-deputy risks in LLM agent code.",
  "version": "0.1.0",
  "publisher": "sanjaybk7",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "keywords": ["security", "ai", "agents", "prompt-injection", "owasp", "langgraph"],
  "activationEvents": ["onLanguage:python"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "agentguard",
      "properties": {
        "agentguard.cliPath": {
          "type": "string",
          "default": "agentguard",
          "description": "Path to the agentguard CLI executable. Defaults to looking it up on PATH."
        },
        "agentguard.runOn": {
          "type": "string",
          "enum": ["save", "manual"],
          "default": "save",
          "description": "When to run the scanner."
        }
      }
    },
    "commands": [
      {
        "command": "agentguard.scanWorkspace",
        "title": "agentguard: Scan workspace"
      },
      {
        "command": "agentguard.scanFile",
        "title": "agentguard: Scan current file"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sanjaybk7/agentguard.git"
  }
}
